# ============================================================
# Genie Space SP Demo v2 — environment variables
# ------------------------------------------------------------
# v2 adds:
#   - Agent layer (Claude via Foundation Model API) orchestrating Genie
#   - Lakebase (Postgres) for LangGraph checkpointing + app-side conv metadata
#   - Summary-based memory compression
# Copy to `.env` and fill in values. `.env` is gitignored.
# ============================================================

# ----- Databricks workspace -----
DBX_HOST=https://<your-workspace>.cloud.databricks.com
DBX_PROFILE=<cli profile configured via `databricks auth login`>
DBX_WAREHOUSE_ID=<serverless SQL warehouse id>  # used by seed scripts + MLflow UC trace export

DBX_CATALOG=abhilash_r
DBX_SCHEMA=genie_demo

# ----- Genie space -----
GENIE_SPACE_ID=

# ----- Service Principals -----
SP_NORTHSTAR_CLIENT_ID=
SP_NORTHSTAR_SECRET=
SP_NORTHSTAR_DEALERSHIP="North Star Motors"
SP_NORTHSTAR_APP_ID=

SP_SUNRISE_CLIENT_ID=
SP_SUNRISE_SECRET=
SP_SUNRISE_DEALERSHIP="Sunrise Auto Group"
SP_SUNRISE_APP_ID=

# ----- Local session / app -----
APP_SESSION_SECRET=
BACKEND_HOST=127.0.0.1
# v1 runs on 8001; keep v2 on a distinct port so both can run side by side.
BACKEND_PORT=8002
FRONTEND_PORT=5174

# ============================================================
# v2 additions — fill these in after you provision Lakebase
# ============================================================

# ----- Lakebase (Postgres OLTP) -----
# Provision a Lakebase instance in the Databricks UI or CLI, then paste its
# psycopg URI here. Format:
#   postgresql://<user>:<pw>@<host>:<port>/<db>?sslmode=require
# The app auto-creates:
#   - LangGraph checkpoint tables (checkpoints, checkpoint_blobs, checkpoint_writes)
#   - app_conversations (our thread pointer table)
LAKEBASE_PG_URI=postgresql://REPLACE_ME:REPLACE_ME@REPLACE_ME.database.cloud.databricks.com:5432/databricks_postgres?sslmode=require

# ----- Foundation Model endpoint (Claude via Databricks FM API) -----
# Default endpoint names on Databricks FM API. Change if your workspace
# uses a different serving endpoint name.
FM_ENDPOINT_NAME=databricks-claude-sonnet-4
FM_TEMPERATURE=0.2
FM_MAX_TOKENS=2048

# ----- Memory compression thresholds -----
# Summarization fires when EITHER threshold is exceeded.
# During a demo, crank these down to see compression happen inside 2-3 turns.
SUMMARY_TURN_THRESHOLD=12
SUMMARY_TOKEN_THRESHOLD=6000
# Messages to keep verbatim after summarization (the tail).
SUMMARY_KEEP_LAST=4

# ----- Genie spaces (multi-space routing) -----
# v2 supports multiple Genie spaces. The supervisor reads the scope strings
# below and routes each question to the right space — or refuses if the
# question falls outside every configured scope.
#
# Sales & Service space (required — primary)
GENIE_SPACE_SALES_ID=
GENIE_SPACE_SALES_SCOPE="In scope: completed vehicle sales and service-ticket data. Out of scope: CRM / pipeline."
#
# ----- MLflow tracing for the LangGraph agent -----
# Local file store (default): view traces with `uv run mlflow ui` in another terminal.
# Databricks workspace: MLFLOW_TRACKING_URI=databricks + absolute experiment path.
MLFLOW_ENABLED=true
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=genie-sp-demo-v2

# CRM / Pipeline space (optional — leave blank until you run setup_crm_databricks.py)
GENIE_SPACE_CRM_ID=
GENIE_SPACE_CRM_SCOPE="In scope: open leads, pipeline opportunities by stage, forecasts, sales targets vs actuals. Out of scope: completed sales history (use the Sales space)."
#
# Legacy single-space fallback (still honored by config.py so v1-style envs work).
# Set GENIE_SPACE_SALES_ID / SCOPE above and leave these blank for v2.
GENIE_SPACE_ID=
GENIE_SPACE_SCOPE=
